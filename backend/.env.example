# Server Port Configuration
PORT=5000

# MongoDB Connection String (Replace with your local connection or MongoDB Atlas cluster URI)
MONGODB_URI=mongodb://127.0.0.1:27017/docvault

# Cloudinary credentials configuration (Obtained from your Cloudinary console dashboard)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
