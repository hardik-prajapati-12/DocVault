{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-production-backend-url.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://your-production-backend-url.com/uploads/:path*"
    },
    {
      "source": "/((?!assets|favicon.svg|pwa-192x192.png|pwa-512x512.png|pwa-192x192.svg|pwa-512x512.svg|sw.js|workbox-).*)",
      "destination": "/index.html"
    }
  ]
}
